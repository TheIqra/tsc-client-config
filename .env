# All requests must include:  X-API-KEY: <this value>
X_API_KEY=9f3b2c6e1a7d4f8b5c0e2a9d6f1b3c7e8a4d0f5c2b9e6a1d7c3f8b4e0a2d6c1

# Local Redis (default):
REDIS_URL=redis://localhost:6379/0

# Production example (with password):
# REDIS_URL=redis://:your_password@redis-host:6379/0

# Cache TTL in seconds (how long channel configs are kept in Redis)
CACHE_TTL_SECONDS=300